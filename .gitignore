# ============================================
# SAND Thesis Reproduction - Clean .gitignore
# ============================================
# Only track: scripts, configs, docs, environment files
# Regenerate everything else via `make all`

# ===================
# R Data & Outputs
# ===================
*.RData
*.rds
*.Rhistory
*.RProj.user
.Rproj.user/

# ===================
# Generated Outputs
# ===================
# Outputs (regenerated by pipeline)
reproduced/outputs/*
reproduced/logs/*
reproduced/analyses/**/outputs/*.csv
reproduced/analyses/**/outputs/*.json

# Figures and plots
*.png
*.jpg
*.jpeg
*.pdf
*.svg
reproduced/outputs/**/*.png
reproduced/outputs/**/*.pdf

# RSiena text outputs
reproduced/saom_*.txt

# Binary artifacts
reproduced/outputs/**/*.rds
reproduced/outputs/**/*.RData
analyses/**/outputs/*.rds
analyses/**/outputs/*.png
outputs/**/*.png

# ===================
# Legacy Folders (not needed for reproduction)
# ===================
SAND_norms_1009/
10_05_final/
shang_thesis_march/
shang_thesis_may/
thesis_reproduction/
/archive/

reproduced/outputs-backup/*


# ===================
# Cache & Temp Files
# ===================
__pycache__/
*.pyc
.cache/
*.log
*.tar.gz
*.zip

# ===================
# Local Secrets & Tool Configuration
# ===================
.env
.env.*
!.env.example
.mcp.json
*.pem
*.key
credentials.json
secrets.json

# ===================
# Environment (keep lockfiles, ignore installed packages)
# ===================
/renv/
renv/library/
renv/staging/
renv/cellar/
.Renv
.conda/
reproduced/.Rlib/

# ===================
# IDE & OS
# ===================
.vscode/
.kiro/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===================
# README Assets (tracked for GitHub rendering)
# ===================
!docs/readme-assets/
!docs/readme-assets/**
!reproduced/docs/portfolio/assets/
!reproduced/docs/portfolio/assets/**

# ===================
# Keep These (explicit exceptions)
# ===================
# Raw data should never be tracked; stage real data locally.
reproduced/data/raw/**
!reproduced/data/raw/README.md

# Config files
!reproduced/config/**/*.yml
!reproduced/config/**/*.yaml

# Generated proxy inputs and metadata. Regenerate with `make proxy-data`.
reproduced/data/proxy/participants.csv
reproduced/data/proxy/outcomes.csv
reproduced/data/proxy/.chapter4_synthetic
reproduced/data/proxy/.realistic_proxy_data
reproduced/data/proxy/proxy_data_generation_report.json

# Essential docs
!reproduced/docs/**/*.md
!*.md

# Lockfiles for reproducibility
!reproduced/renv.lock
!reproduced/environment.yml
